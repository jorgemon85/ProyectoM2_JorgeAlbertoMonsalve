# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env a GitHub

# Puerto donde corre el servidor localmente
PUERTO=3000

# Conexión a PostgreSQL local (para desarrollo)
DB_HOST=localhost
DB_PUERTO=5432
DB_NOMBRE=miniblog_db
DB_USUARIO=postgres
DB_PASSWORD=tu_password_aqui

# Conexión a PostgreSQL en Railway (se completa al hacer el deploy)
# DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# SSL para Railway (cambiar a true en producción)
DATABASE_SSL=false
